HOST=0.0.0.0
PORT=8000

# Set true for local smoke tests without GPU model weights.
MOCK_MODE=false

WORKSPACE_DIR=/workspace
OUTPUT_DIR=/workspace/outputs
JOBS_DIR=/workspace/jobs

# Official Tencent-Hunyuan repo path inside pod.
HUNYUAN_REPO_DIR=/workspace/HunyuanVideo-I2V
HUNYUAN_PYTHON=python3

DEFAULT_MODEL=HYVideo-T/2
DEFAULT_RESOLUTION=720p
DEFAULT_VIDEO_LENGTH=129
DEFAULT_INFER_STEPS=50
DEFAULT_EMBEDDED_CFG_SCALE=6.0
DEFAULT_FLOW_SHIFT_STABLE=7.0
DEFAULT_FLOW_SHIFT_DYNAMIC=17.0
